# Copiar a `.env` (no commitear). Expo carga EXPO_PUBLIC_* automáticamente.
EXPO_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anon

# Opcional: API Next/dashboard para onboarding y marcaje vía backend
# EXPO_PUBLIC_QUANTIX_API_URL=https://tu-dominio.com

# Sentry (recomendado en producción). Ver `lib/sentryInit.ts`: en release `debug` va en false salvo que actives lo de abajo.
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# En desarrollo, debug del SDK está activo por defecto; desactivar con: EXPO_PUBLIC_SENTRY_DEBUG=0
# En producción/stores, activar solo para diagnóstico puntual: EXPO_PUBLIC_SENTRY_DEBUG=1

# Opcional: solo web para reset de contraseña si no usas scheme nativo
# EXPO_PUBLIC_PASSWORD_RESET_WEB_URL=https://quantixhr.com/actualizar-password

# Opcional: muestra el acceso al panel gerencial aunque el rol no sea admin/manager (solo pruebas)
# EXPO_PUBLIC_FORCE_ADMIN_PANEL=true
